{
  "manifest_version": 3,
  "default_locale": "zh_CN",
  "name": "启迪AI辅助评价",
  "version": "1.0.0",
  "description": "启迪AI辅助评价工具，适用于www.qidi-edu.com",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.qidi-edu.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.qidi-edu.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    },
    "default_title": "启迪AI辅助评价"
  },
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
